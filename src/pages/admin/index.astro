---
import Layout from '../../layouts/Layout.astro';
import { getContent } from '../../utils/content';
import { isAuthenticated } from '../../utils/auth';

export const prerender = false;

const isAuth = isAuthenticated(Astro.cookies);
const content = getContent();
const contentStr = JSON.stringify(content, null, 2);
---

<Layout title="Mobilab Admin Panel">
  {!isAuth ? (
    <div class="login-overlay">
      <div class="glass-card login-box">
        <h2>Admin Girişi</h2>
        <input type="password" id="passwordInput" placeholder="Şifre Giriniz" class="modern-input" />
        <button id="loginBtn" class="btn-primary">Giriş Yap</button>
        <p id="loginError" class="error-text"></p>
      </div>
    </div>
  ) : (
    <div class="admin-container">
      <header class="admin-header">
        <div class="header-left">
          <h1>Mobilab Yönetim</h1>
          <span class="badge">v2.0</span>
        </div>
        <div class="actions">
          <a href="/" target="_blank" class="btn-secondary">Siteyi Önizle</a>
          <button id="saveBtn" class="btn-primary">Canlıya Al (Kaydet)</button>
        </div>
      </header>
  
      <div class="admin-tabs">
        <button class="tab-btn active" data-tab="general">Genel & Hero</button>
        <button class="tab-btn" data-tab="projects">Projeler</button>
        <button class="tab-btn" data-tab="education">Eğitimler</button>
        <button class="tab-btn" data-tab="team">Ekip & Blog</button>
        <button class="tab-btn" data-tab="json">Gelişmiş (JSON)</button>
        <button class="tab-btn" data-tab="backup">Yedekleme</button>
      </div>
  
      <div class="tab-content active" id="general">
        <div class="glass-card panel">
          <h3>Hero Düzenle</h3>
          <p class="hint">Ana sayfanın en üst kısmı.</p>
          <div class="form-group">
            <label>Ana Başlık</label>
            <input type="text" class="modern-input edit-field" data-path="hero.mainTitle" />
          </div>
          <div class="form-group">
             <label>Alt Başlık</label>
             <input type="text" class="modern-input edit-field" data-path="hero.description" />
          </div>
          <div class="form-group">
             <label>Background URL (Unsplash önerilir)</label>
             <input type="text" class="modern-input edit-field" data-path="hero.backgroundImage" />
          </div>
        </div>
        
        <div class="glass-card panel" style="margin-top:2rem;">
            <h3>Hakkımızda</h3>
            <div class="form-group">
                <label>Başlık</label>
                <input type="text" class="modern-input edit-field" data-path="about.title" />
            </div>
            <div class="form-group">
                <label>İçerik</label>
                <textarea class="modern-input edit-field" data-path="about.content" rows="4"></textarea>
            </div>
        </div>
      </div>

      <div class="tab-content" id="projects">
        <div class="glass-card panel">
           <h3>Projeler</h3>
           <p class="hint">Projeleri düzenlemek için JSON sekmesini kullanın veya aşağıdan metinleri hızlıca düzenleyin.</p>
           <div id="projectsList"></div>
        </div>
      </div>
  
      <div class="tab-content" id="education">
          <div class="glass-card panel">
             <h3>Eğitimler</h3>
             <div id="eduList"></div>
          </div>
      </div>

      <div class="tab-content" id="team">
         <div class="glass-card panel">
            <h3>Ekip Üyeleri</h3>
            <div id="teamList"></div>
         </div>
         <div class="glass-card panel" style="margin-top: 2rem;">
            <h3>Blog Yazıları</h3>
            <div id="blogList"></div>
         </div>
      </div>
  
      <div class="tab-content" id="json">
        <div class="editor-wrapper glass-card">
          <div class="toolbar">
            <span>FULL EDIT MODE</span>
            <span class="warning">Dikkat: Yapıyı bozmayın.</span>
          </div>
          <textarea id="jsonEditor" spellcheck="false">{contentStr}</textarea>
        </div>
      </div>
  
      <div class="tab-content" id="backup">
        <div class="glass-card panel backup-panel">
          <div class="backup-actions">
             <div class="action-box">
                <h3>Yedek Al</h3>
                <p>Mevcut sitenin tüm içeriğini bilgisayarına indir.</p>
                <a href="/api/backup" class="btn-primary full-width center-text" download>Yedeği İndir (.json)</a>
             </div>
             
             <div class="divider"></div>
             
             <div class="action-box">
                <h3>Yedekten Dön</h3>
                <p>Eski bir yedeği yükleyerek sistemi geri al.</p>
                <input type="file" id="restoreInput" accept=".json" class="file-input" />
                <label for="restoreInput" class="btn-secondary full-width center-text">Dosya Seç ve Yükle</label>
             </div>
          </div>
        </div>
      </div>
  
    </div>
  )}
</Layout>

<script>
  // Auth Logic
  const loginBtn = document.getElementById('loginBtn');
  if (loginBtn) {
    loginBtn.addEventListener('click', async () => {
      const password = (document.getElementById('passwordInput') as HTMLInputElement).value;
      const res = await fetch('/api/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password })
      });
      if (res.ok) {
        window.location.reload();
      } else {
        document.getElementById('loginError').textContent = 'Hatalı şifre!';
      }
    });
  }

  // Admin Logic
  let content = JSON.parse(document.getElementById('jsonEditor')?.textContent || '{}');
  const jsonEditor = document.getElementById('jsonEditor') as HTMLTextAreaElement;
  
  // Tab Switching
  const tabs = document.querySelectorAll('.tab-btn');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      
      tab.classList.add('active');
      document.getElementById(tab.getAttribute('data-tab')).classList.add('active');
      
      // Sync edits to JSON view when switching to it
      if (tab.getAttribute('data-tab') === 'json') {
          syncFieldsToJSON();
      } else {
          // Sync JSON to fields when switching away from JSON (if user edited JSON manually)
          try {
             const freshContent = JSON.parse(jsonEditor.value);
             populateFields(freshContent);
          } catch(e) {
             console.error("Invalid JSON in editor");
          }
      }
    });
  });

  // Helper: Get nested property
  const getNested = (obj, path) => path.split('.').reduce((o, i) => o ? o[i] : null, obj);
  // Helper: Set nested property
  const setNested = (obj, path, value) => {
     const parts = path.split('.');
     let current = obj;
     for(let i=0; i<parts.length-1; i++) {
        current = current[parts[i]];
     }
     current[parts[parts.length-1]] = value;
  }

  function populateFields(data) {
    // Auto-populate inputs with data-path
    document.querySelectorAll('.edit-field').forEach((input: any) => {
       const path = input.getAttribute('data-path');
       const val = getNested(data, path);
       if(val !== undefined) input.value = val;
    });

    // Populate Dynamic Lists (Projects, etc) if empty
    // Simplified for this demo: Just listing titles to show it works
    const projContainer = document.getElementById('projectsList');
    if(projContainer && projContainer.innerHTML === '') {
        data.projects.items.forEach((item, idx) => {
            projContainer.innerHTML += `
               <div class="list-item">
                  <strong>${item.title}</strong>
                  <input type="text" class="modern-input edit-list" data-list="projects" data-idx="${idx}" data-key="title" value="${item.title}" />
               </div>
            `;
        });
    }
  }

  function syncFieldsToJSON() {
    // 1. Inputs with data-path
    document.querySelectorAll('.edit-field').forEach((input: any) => {
       setNested(content, input.getAttribute('data-path'), input.value);
    });
    
    // 2. Dynamic lists
    document.querySelectorAll('.edit-list').forEach((input: any) => {
        const listName = input.getAttribute('data-list');
        const idx = input.getAttribute('data-idx');
        const key = input.getAttribute('data-key');
        if(content[listName] && content[listName].items[idx]) {
            content[listName].items[idx][key] = input.value;
        }
    });

    jsonEditor.value = JSON.stringify(content, null, 2);
  }

  // Initial Population
  if(jsonEditor) {
      populateFields(content);
      
      // Save Logic
      document.getElementById('saveBtn').addEventListener('click', async () => {
         const btn = document.getElementById('saveBtn');
         try {
            syncFieldsToJSON(); // Ensure JSON is up to date from inputs
            const finalData = JSON.parse(jsonEditor.value); // Get from editor (source of truth)
            
            btn.textContent = 'Kaydediliyor...';
            btn.disabled = true;
            
            const res = await fetch('/api/save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(finalData)
            });
            
            if(res.ok) {
                alert('Başarıyla Güncellendi!');
            } else {
                alert('Hata Oluştu!');
            }
         } catch(e) {
            alert('JSON Hatası: ' + e.message);
         } finally {
            btn.textContent = 'Canlıya Al (Kaydet)';
            btn.disabled = false;
         }
      });
      
      // Restore Logic
      const restoreInput = document.getElementById('restoreInput');
      if(restoreInput) {
          restoreInput.addEventListener('change', (e: any) => {
              const file = e.target.files[0];
              if(!file) return;
              const reader = new FileReader();
              reader.onload = (evt) => {
                  try {
                      const json = JSON.parse(evt.target.result as string);
                      jsonEditor.value = JSON.stringify(json, null, 2);
                      content = json; // Update local state
                      populateFields(json);
                      alert('Yedek Yüklendi. Kaydet tuşuna basarak canlıya alabilirsiniz.');
                  } catch(err) {
                      alert('Dosya bozuk.');
                  }
              }
              reader.readAsText(file);
          });
      }
  }
</script>

<style>
  .login-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.8);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
  }
  
  .login-box {
    padding: 2rem;
    width: 100%;
    max-width: 400px;
    text-align: center;
  }

  .admin-container {
    padding: 120px 2rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .admin-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }
  
  .badge { background: #ffbd2e; color: black; padding: 2px 8px; border-radius: 4px; font-size: 0.8rem; font-weight: bold; margin-left: 10px;}

  .admin-tabs {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    overflow-x: auto;
    padding-bottom: 1rem;
  }

  .tab-btn {
    background: transparent;
    border: none;
    padding: 0.8rem 1.5rem;
    color: var(--text-secondary);
    font-weight: 600;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
  }

  .tab-btn:hover { color: var(--text-primary); }
  
  .tab-btn.active {
    color: var(--brand-color);
    border-bottom: 2px solid var(--brand-color);
  }

  .tab-content { display: none; }
  .tab-content.active { display: block; animation: fadeIn 0.3s ease; }

  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  .panel { padding: 2rem; margin-bottom: 2rem; }
  .panel h3 { margin-bottom: 1rem; color: var(--text-primary); }
  .hint { color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 1.5rem; }

  .form-group { margin-bottom: 1.5rem; }
  .form-group label { display: block; margin-bottom: 0.5rem; font-weight: 500; font-size: 0.9rem; }

  .modern-input {
    width: 100%;
    padding: 1rem;
    border-radius: 12px;
    border: 1px solid var(--border-color);
    background: rgba(255,255,255,0.05);
    color: var(--text-primary);
    font-size: 1rem;
    transition: all 0.2s;
  }

  .modern-input:focus {
    border-color: var(--brand-color);
    outline: none;
    box-shadow: 0 0 0 3px var(--brand-glow);
  }

  .editor-wrapper {
     height: 600px;
     display: flex;
     flex-direction: column;
     padding: 0;
     overflow: hidden;
  }

  .toolbar { padding: 0.5rem 1rem; background: rgba(0,0,0,0.2); font-size: 0.8rem; display: flex; justify-content: space-between; }
  .warning { color: #ff5f56; }

  #jsonEditor {
    flex: 1;
    background: #1e1e1e;
    color: #d4d4d4;
    padding: 1rem;
    border: none;
    resize: none;
    font-family: 'Fira Code', monospace;
  }
  
  .list-item {
     display: flex;
     align-items: center;
     gap: 1rem;
     margin-bottom: 1rem;
     padding-bottom: 1rem;
     border-bottom: 1px solid var(--border-color);
  }
  
  .backup-panel { text-align: center; }
  .backup-actions { display: flex; justify-content: space-around; flex-wrap: wrap; gap: 2rem; }
  .action-box { flex: 1; min-width: 250px; }
  .file-input { margin: 1rem 0; display: none; }
  .full-width { display: block; width: 100%; margin-top: 1rem; }
  .center-text { text-align: center; }
</style>

---
import Layout from "../../layouts/Layout.astro";
import { getEducationData } from "../../utils/keystatic";

export const prerender = false;

const { id } = Astro.params;
const educationData = await getEducationData();
const edu = educationData.items.find((e) => e.id === id);

if (!edu) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}
---

<Layout title={`${edu.title} - Eğitimler`}>
  <article class="detail-page section-padding">
    <div class="container">
      <a href="/#education" class="back-link">&larr; Geri Dön</a>

      <div class="header-content">
        <h1>{edu.title}</h1>
        <p class="subtitle">{edu.description}</p>
      </div>

      <div
        class="featured-image glass-card"
        style={`background-image: url('${edu.image}');`}
      >
      </div>

      <div class="content user-content">
        <p>{edu.fullDescription || edu.description}</p>
      </div>
    </div>
  </article>
</Layout>

<style>
  .detail-page {
    padding-top: 100px;
  }
  .back-link {
    color: var(--text-secondary);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 2rem;
  }
  .header-content {
    margin-bottom: 3rem;
    max-width: 800px;
  }
  .subtitle {
    font-size: 1.2rem;
    color: var(--text-secondary);
    margin-top: 1rem;
  }
  .featured-image {
    width: 100%;
    height: 400px;
    background-size: cover;
    background-position: center;
    border-radius: 12px;
    margin-bottom: 3rem;
  }
  .user-content {
    max-width: 800px;
    font-size: 1.1rem;
    line-height: 1.8;
  }
</style>

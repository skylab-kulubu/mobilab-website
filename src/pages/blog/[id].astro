---
import Layout from '../../layouts/Layout.astro';
import { getContent } from '../../utils/content';

export const prerender = false;

const { id } = Astro.params;
const content = getContent();
const post = content.blog.items.find(p => p.id === id);

if (!post) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}
---

<Layout title={`${post.title} - Blog`}>
  <article class="blog-post section-padding">
    <div class="container blog-container">
      <a href="/#blog" class="back-link">&larr; Blog'a Dön</a>
      
      <div class="post-header">
        <span class="post-date">{post.date}</span>
        <h1>{post.title}</h1>
      </div>

      <div class="post-image" style={`background-image: url('${post.image}');`}></div>

      <div class="post-content user-content">
        <p class="lead">{post.excerpt}</p>
        <hr />
        <div>{post.content}</div>
        <p><em>(Buraya Admin panelden tam içerik eklenebilir)</em></p>
      </div>
    </div>
  </article>
</Layout>

<style>
  .blog-post { padding-top: 100px; }
  .blog-container { max-width: 800px; }
  .back-link { text-decoration: none; color: var(--text-secondary); display: block; margin-bottom: 2rem; }
  .post-header { margin-bottom: 2rem; text-align: center; }
  .post-date { color: var(--brand-color); font-weight: 500; font-size: 0.9rem; }
  h1 { font-size: 2.5rem; margin-top: 0.5rem; }
  .post-image { width: 100%; height: 400px; background-size: cover; background-position: center; border-radius: 16px; margin-bottom: 3rem; }
  .user-content { font-size: 1.1rem; line-height: 1.8; color: var(--text-secondary); }
  .lead { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 2rem; }
  hr { border: 0; border-top: 1px solid var(--border-color); margin: 2rem 0; }
</style>

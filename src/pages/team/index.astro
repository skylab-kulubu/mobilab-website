---
import Layout from '../../layouts/Layout.astro';
import { getContent } from '../../utils/content';

const content = getContent();
const team = content.team;
---

<Layout title="Ekibimiz | Mobilab">
  <section class="page-hero">
    <div class="container">
      <span class="page-label">Ekip</span>
      <h1>{team?.sectionTitle || "Ekibimiz"}</h1>
      <p class="page-description">{team?.description || "Mobilab'ı oluşturan insanlar."}</p>
    </div>
  </section>

  <section class="team-page section-padding">
    <div class="container">
      <div class="team-grid">
        {team?.members?.map((member) => (
          <div class="team-card glass-card">
            <div class="avatar">
              <span>{member.abbr}</span>
            </div>
            <div class="member-info">
              <h3 class="member-name">{member.name}</h3>
              <span class="member-role">{member.role}</span>
            </div>
            <div class="social-links">
              <a href="#" class="social-link" title="LinkedIn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
              <a href="#" class="social-link" title="GitHub">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>

      <div class="cta-section">
        <div class="cta-card glass-card">
          <h2>Ekibe Katılmak İster misin?</h2>
          <p>Mobilab ailesinin bir parçası ol, birlikte harika projeler geliştirelim.</p>
          <a href="/#contact" class="btn-primary">Başvur</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: 140px 0 60px;
    text-align: center;
    background: var(--bg-secondary);
  }

  .page-label {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: rgba(0, 122, 255, 0.1);
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1rem;
  }

  @media (prefers-color-scheme: dark) {
    .page-label {
      background: rgba(10, 132, 255, 0.15);
    }
  }

  .page-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 1rem;
  }

  .page-description {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 auto;
  }

  .team-page {
    background: var(--bg-primary);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .team-card {
    padding: 2rem;
    text-align: center;
  }

  .avatar {
    width: 100px;
    height: 100px;
    margin: 0 auto 1.5rem;
    background: var(--primary-gradient);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .avatar span {
    font-size: 2rem;
    font-weight: 700;
    color: #fff;
  }

  .member-info {
    margin-bottom: 1.5rem;
  }

  .member-name {
    font-size: 1.25rem;
    margin-bottom: 0.25rem;
  }

  .member-role {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .social-links {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--bg-secondary);
    border-radius: 10px;
    color: var(--text-muted);
    transition: all 0.2s;
  }

  @media (prefers-color-scheme: dark) {
    .social-link {
      background: var(--bg-tertiary);
    }
  }

  .social-link:hover {
    background: var(--primary);
    color: #fff;
  }

  .cta-section {
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-card {
    padding: 3rem;
    text-align: center;
  }

  .cta-card h2 {
    margin-bottom: 0.75rem;
  }

  .cta-card p {
    margin-bottom: 1.5rem;
  }
</style>

---
const { data } = Astro.props;
const items = data?.items || [
    { id: 1, title: "Flutter 3.29 Neler Getiriyor?", date: "15 Ocak 2026", excerpt: "Impeller motorunun son durumu ve yeni Material 4 widget setleri.", image: "https://images.unsplash.com/photo-1617042375876-a13e36732a04?q=80&w=600&auto=format&fit=crop" },
    { id: 2, title: "Riverpod vs Bloc: Hangisi?", date: "10 Ocak 2026", excerpt: "State management savaşlarında son durum.", image: "https://images.unsplash.com/photo-1461749280684-dccba630e2f6?q=80&w=600&auto=format&fit=crop" },
    { id: 3, title: "Mobil Güvenlik 101", date: "28 Aralık 2025", excerpt: "API anahtarlarınızı saklamanın en güvenli yolları.", image: "https://images.unsplash.com/photo-1555949963-ff9fe0c870eb?q=80&w=600&auto=format&fit=crop" }
];
---

<section id="blog" class="blog-section section-padding">
  <div class="container">
    <div class="section-header reveal-item">
      <span class="section-label">Blog</span>
      <h2 class="section-title">Son Yazılar</h2>
      <p class="section-description">Mobil geliştirme dünyasından haberler</p>
    </div>

    <div class="blog-grid">
      {items.map((item) => (
        <a href={`/blog/${item.id}`} class="blog-card glass-card reveal-item">
          <div class="card-image" style={`background-image: url('${item.image}');`}></div>
          <div class="card-content">
            <span class="card-date">{item.date}</span>
            <h4 class="card-title">{item.title}</h4>
            <p class="card-excerpt">{item.excerpt}</p>
            <span class="read-more">
              Devamını Oku
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>
    
    <div class="center-btn reveal-item">
      <a href="/blog" class="btn-secondary">Tüm Yazıları Gör</a>
    </div>
  </div>
</section>

<style>
  .blog-section {
    background: var(--bg-primary);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .card-image {
    height: 180px;
    background-size: cover;
    background-position: center;
    border-radius: 16px 16px 0 0;
  }

  .card-content {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .card-date {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .card-title {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
    line-height: 1.3;
  }

  .card-excerpt {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
    flex-grow: 1;
    margin-bottom: 1rem;
  }

  .read-more {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--primary);
    font-weight: 600;
    font-size: 0.875rem;
  }

  .read-more svg {
    transition: transform var(--transition-fast);
  }

  .blog-card:hover .read-more svg {
    transform: translateX(4px);
  }
</style>

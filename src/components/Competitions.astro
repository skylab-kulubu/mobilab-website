---
const { data } = Astro.props;
---

<section id="competitions" class="competitions-section section-padding">
  <div class="container">
    <div class="section-header reveal-item">
      <span class="section-label">Başarılar</span>
      <h2 class="section-title">{data.sectionTitle}</h2>
      <p class="section-description">{data.description}</p>
    </div>

    <div class="timeline">
      {data.items.map((item, index) => (
        <div class={`timeline-item reveal-item ${index % 2 === 0 ? 'left' : 'right'}`}>
          <div class="timeline-dot"></div>
          <div class="timeline-card glass-card">
            <div class="card-header">
              <span class="event-date">{item.date}</span>
              <span class={`status-badge ${item.status.toLowerCase().includes('kazandı') ? 'success' : ''}`}>
                {item.status}
              </span>
            </div>
            <h4 class="card-title">{item.title}</h4>
            <span class="event-name">{item.event}</span>
            <p class="card-description">{item.description}</p>
            <div class="card-tags">
              <span class="tag">{item.category}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <div class="center-btn reveal-item">
      <a href="/competitions" class="btn-secondary">Tüm Yarışmaları Gör</a>
    </div>
  </div>
</section>

<style>
  .competitions-section {
    background: var(--bg-primary);
  }

  .timeline {
    position: relative;
    max-width: 800px;
    margin: 0 auto 2rem;
    padding: 2rem 0;
  }

  .timeline::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 2px;
    background: var(--border-color);
    transform: translateX(-50%);
  }

  .timeline-item {
    position: relative;
    display: flex;
    margin-bottom: 2rem;
    padding: 0 50px;
  }

  .timeline-item.left {
    justify-content: flex-start;
  }

  .timeline-item.right {
    justify-content: flex-end;
  }

  .timeline-dot {
    position: absolute;
    left: 50%;
    top: 20px;
    width: 14px;
    height: 14px;
    background: var(--primary);
    border-radius: 50%;
    border: 3px solid var(--bg-primary);
    transform: translateX(-50%);
    z-index: 2;
  }

  .timeline-card {
    width: calc(50% - 30px);
    padding: 1.25rem;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .event-date {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .status-badge {
    padding: 4px 10px;
    background: rgba(0, 122, 255, 0.1);
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--primary);
  }

  .status-badge.success {
    background: rgba(39, 201, 63, 0.15);
    color: #27c93f;
  }

  @media (prefers-color-scheme: dark) {
    .status-badge {
      background: rgba(10, 132, 255, 0.2);
    }
  }

  .card-title {
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
    color: var(--text-primary);
  }

  .event-name {
    font-size: 0.85rem;
    color: var(--primary);
    font-weight: 500;
    display: block;
    margin-bottom: 0.75rem;
  }

  .card-description {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }

  .card-tags {
    display: flex;
    gap: 6px;
  }

  .tag {
    padding: 4px 8px;
    background: var(--bg-secondary);
    border-radius: 6px;
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .timeline::before {
      left: 20px;
    }

    .timeline-dot {
      left: 20px;
    }

    .timeline-item {
      padding: 0 0 0 50px;
      justify-content: flex-start !important;
    }

    .timeline-card {
      width: 100%;
    }
  }
</style>

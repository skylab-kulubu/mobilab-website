---
const { data } = Astro.props;
---

<section id="education" class="education-section section-padding">
  <div class="container">
    <div class="section-header reveal-item">
      <span class="section-label">Eğitimler</span>
      <h2 class="section-title">{data.sectionTitle}</h2>
      <p class="section-description">{data.description}</p>
    </div>

    <div class="education-grid">
      {data.items.slice(0, 3).map((item) => (
        <a href={`/education/${item.id}`} class="education-card glass-card reveal-item">
          <div class="card-image" style={`background-image: url('${item.image}');`}></div>
          <div class="card-content">
            <h4 class="card-title">{item.title}</h4>
            <p class="card-excerpt">{item.description.substring(0, 100)}...</p>
            <span class="read-more">
              İncele
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>
    
    <div class="center-btn reveal-item">
      <a href="/education" class="btn-secondary">Tüm Eğitimleri Gör</a>
    </div>
  </div>
</section>

<style>
  .education-section {
    background: var(--bg-primary);
  }

  .education-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .education-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .card-image {
    height: 180px;
    background-size: cover;
    background-position: center;
    border-radius: 16px 16px 0 0;
  }

  .card-content {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .card-title {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
  }

  .card-excerpt {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
    flex-grow: 1;
    margin-bottom: 1rem;
  }

  .read-more {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--primary);
    font-weight: 600;
    font-size: 0.875rem;
  }

  .read-more svg {
    transition: transform var(--transition-fast);
  }

  .education-card:hover .read-more svg {
    transform: translateX(4px);
  }
</style>

---
import Layout from "../../layouts/Layout.astro";
import { getCompetitionsData } from "../../utils/keystatic";

const content = await getCompetitionsData();
const competitions = content;
---

<Layout title="Başarılarımız | Mobilab">
  <section class="page-hero">
    <div class="container">
      <span class="page-label">Başarılar</span>
      <h1>{competitions?.sectionTitle || "Başarılarımız"}</h1>
      <p class="page-description">
        {competitions?.description || "Yarışmalarda elde ettiğimiz ödüller."}
      </p>
    </div>
  </section>

  <section class="competitions-page section-padding">
    <div class="container">
      <div class="competitions-grid">
        {
          competitions?.items?.map((item) => (
            <div class="competition-card glass-card">
              <div
                class="card-image"
                style={`background-image: url('${item.image}');`}
              >
                <div class="status-badge">{item.status}</div>
              </div>
              <div class="card-content">
                <div class="card-meta">
                  <span class="card-date">{item.date}</span>
                  <span class="card-category">{item.category}</span>
                </div>
                <h3 class="card-title">{item.title}</h3>
                <span class="card-event">{item.event}</span>
                <p class="card-description">{item.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: 140px 0 60px;
    text-align: center;
    background: var(--bg-secondary);
  }

  .page-label {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: rgba(0, 122, 255, 0.1);
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1rem;
  }

  @media (prefers-color-scheme: dark) {
    .page-label {
      background: rgba(10, 132, 255, 0.15);
    }
  }

  .page-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 1rem;
  }

  .page-description {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 auto;
  }

  .competitions-page {
    background: var(--bg-primary);
  }

  .competitions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
    gap: 1.5rem;
  }

  .competition-card {
    overflow: hidden;
  }

  .card-image {
    height: 200px;
    background-size: cover;
    background-position: center;
    position: relative;
  }

  .status-badge {
    position: absolute;
    top: 16px;
    right: 16px;
    padding: 6px 14px;
    background: rgba(39, 201, 63, 0.9);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    border-radius: 8px;
    text-transform: uppercase;
  }

  .card-content {
    padding: 1.5rem;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .card-date {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .card-category {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--primary);
    text-transform: uppercase;
  }

  .card-title {
    font-size: 1.25rem;
    margin-bottom: 0.25rem;
  }

  .card-event {
    display: block;
    font-size: 0.9rem;
    color: var(--primary);
    font-weight: 500;
    margin-bottom: 0.75rem;
  }

  .card-description {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .competitions-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

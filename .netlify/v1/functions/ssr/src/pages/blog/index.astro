---
import Layout from '../../layouts/Layout.astro';
import { getContent } from '../../utils/content';

const content = getContent();
const blog = content.blog;
---

<Layout title="Blog | Mobilab">
  <section class="page-hero">
    <div class="container">
      <span class="page-label">Blog</span>
      <h1>{blog?.sectionTitle || "Blog"}</h1>
      <p class="page-description">{blog?.description || "Mobil geliştirme dünyasından güncel yazılar."}</p>
    </div>
  </section>

  <section class="blog-page section-padding">
    <div class="container">
      <div class="blog-grid">
        {blog?.items?.map((item) => (
          <a href={`/blog/${item.id}`} class="blog-card glass-card">
            <div class="card-image" style={`background-image: url('${item.image}');`}></div>
            <div class="card-content">
              <span class="card-date">{item.date}</span>
              <h3 class="card-title">{item.title}</h3>
              <p class="card-excerpt">{item.excerpt}</p>
              <span class="read-more">
                Devamını Oku
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: 140px 0 60px;
    text-align: center;
    background: var(--bg-secondary);
  }

  .page-label {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: rgba(0, 122, 255, 0.1);
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1rem;
  }

  @media (prefers-color-scheme: dark) {
    .page-label {
      background: rgba(10, 132, 255, 0.15);
    }
  }

  .page-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 1rem;
  }

  .page-description {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 auto;
  }

  .blog-page {
    background: var(--bg-primary);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .card-image {
    height: 200px;
    background-size: cover;
    background-position: center;
    border-radius: 16px 16px 0 0;
  }

  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .card-date {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .card-title {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .card-excerpt {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
    flex-grow: 1;
    margin-bottom: 1rem;
  }

  .read-more {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--primary);
    font-weight: 600;
    font-size: 0.875rem;
  }

  .read-more svg {
    transition: transform 0.2s;
  }

  .blog-card:hover .read-more svg {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import Layout from "../../layouts/Layout.astro";
import { getProjectsData } from "../../utils/keystatic";

export const prerender = false;

const { id } = Astro.params;
const projectsData = await getProjectsData();
const project = projectsData.items.find((p) => p.id === id);

if (!project) {
  return new Response(null, {
    status: 404,
    statusText: "Not Found",
  });
}
---

<Layout title={`${project.title} - Projeler`}>
  <article class="project-detail section-padding">
    <div class="container">
      <a href="/#projects" class="back-link">&larr; Geri Dön</a>

      <div class="header-content animate-fade-in">
        <span class="category">{project.category}</span>
        <h1>{project.title}</h1>
        <p class="summary">{project.summary}</p>
      </div>

      <div
        class="featured-image glass-card animate-fade-in"
        style={`background-image: url('${project.image}');`}
      >
      </div>

      <div class="content user-content animate-fade-in">
        <p>{project.fullDescription || project.summary}</p>
        <!-- Additional content could be added here from JSON if structure allows -->
      </div>
    </div>
  </article>
</Layout>

<style>
  .project-detail {
    padding-top: 100px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
  }

  .back-link:hover {
    color: var(--brand-color);
  }

  .header-content {
    max-width: 800px;
    margin-bottom: 3rem;
  }

  .category {
    color: var(--brand-color);
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.9rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .summary {
    font-size: 1.2rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .featured-image {
    width: 100%;
    height: 500px;
    background-size: cover;
    background-position: center;
    border-radius: 16px;
    margin-bottom: 3rem;
  }

  .user-content {
    max-width: 800px;
    margin: 0 auto;
    font-size: 1.1rem;
    line-height: 1.8;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2rem;
    }
    .featured-image {
      height: 300px;
    }
  }
</style>
